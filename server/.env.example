# 服务监听
HOST=0.0.0.0
PORT=5011
FLASK_DEBUG=False

# 必须自行生成并设置，切勿使用默认值
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

APPNAME=dna-server

# MySQL（你正在操作的即生产库，任何改表前请先全量备份）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=dna
DB_PASSWORD=
DB_NAME=dna

# SMTP（注册验证邮件）
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 安全与跨域
CORS_ORIGINS=*
TOKEN_MAX_AGE=86400
PASSWORD_MIN_LENGTH=8
